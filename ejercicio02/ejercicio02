#include <iostream>
#include <cmath>

using namespace std;

int main() {
    double x1, y1, x2, y2, x3, y3;

    cout << "Ingrese las coordenadas del primer punto (x1 y y1): ";
    cin >> x1 >> y1;

    cout << "Ingrese las coordenadas del segundo punto (x2 y y2): ";
    cin >> x2 >> y2;

    cout << "Ingrese las coordenadas del tercer punto (x3 y y3): ";
    cin >> x3 >> y3;

    double a = sqrt(pow(x2 - x1, 2) + pow(y2 - y1, 2));
    double b = sqrt(pow(x3 - x2, 2) + pow(y3 - y2, 2));
    double c = sqrt(pow(x1 - x3, 2) + pow(y1 - y3, 2));

    if (a + b > c && a + c > b && b + c > a) {

        cout << "\nLos puntos SI forman un triangulo.\n";

        if (a == b && b == c) {
            cout << "Es un triangulo equilatero.\n";
        } 
        else if (a == b || a == c || b == c) {
            cout << "Es un triangulo isosceles.\n";
        } 
        else {
            cout << "Es un triangulo escaleno.\n";
        }

        double a2 = a * a;
        double b2 = b * b;
        double c2 = c * c;

        if (a2 + b2 == c2 || a2 + c2 == b2 || b2 + c2 == a2) {
            cout << "Es un triangulo rectangulo.\n";
        } 
        else if (a2 + b2 > c2 && a2 + c2 > b2 && b2 + c2 > a2) {
            cout << "Es un triangulo acutangulo.\n";
        } 
        else {
            cout << "Es un triangulo obtusangulo.\n";
        }

    } else {
        cout << "\nLos puntos NO forman un triangulo.\n";
    }

    return 0;
}
